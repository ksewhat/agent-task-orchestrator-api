APP_NAME=Agent Task Orchestrator API
APP_ENV=local

# OpenAI API Key (LLM 기능 사용 시 필요)
OPENAI_API_KEY=your-openai-api-key-here

# 사용할 OpenAI 모델 (기본값: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# PostgreSQL 접속 URL (서버 실행에 필수)
# 형식: postgresql://유저명:비밀번호@호스트:포트/DB명
DATABASE_URL=postgresql://postgres:password@localhost:5432/agent_db
